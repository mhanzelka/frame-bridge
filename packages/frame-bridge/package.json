{
    "name": "@mhanzelka/frame-bridge",
    "version": "0.1.0",
    "description": "Type-safe inter-window and iframe communication via postMessage, BroadcastChannel and MessageChannel",
    "author": "mhanzelka",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./bridge/*": {
            "import": "./dist/bridge/*.js",
            "types": "./dist/bridge/*.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^3.2.0",
        "fast-glob": "^3.3.3",
        "happy-dom": "^17.4.4",
        "rollup-preserve-directives": "^1.1.3",
        "typescript": "^5.9.3",
        "vite": "7.1.11",
        "vite-plugin-dts": "^4.5.4",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.0"
    }
}
