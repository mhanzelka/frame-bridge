<span class="line"></span>
<span class="line"><span style="color:#FF7B72">type</span><span style="color:#FFA657"> Messages</span><span style="color:#FF7B72"> =</span><span style="color:#E6EDF3"> { </span><span style="color:#FFA657">type</span><span style="color:#FF7B72">:</span><span style="color:#A5D6FF"> "ping"</span><span style="color:#FF7B72"> |</span><span style="color:#A5D6FF"> "pong"</span><span style="color:#E6EDF3">; </span><span style="color:#FFA657">value</span><span style="color:#FF7B72">:</span><span style="color:#79C0FF"> number</span><span style="color:#E6EDF3"> };</span></span>
