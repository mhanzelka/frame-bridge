<span class="line"><span style="color:#FF7B72">function</span><span style="color:#D2A8FF"> Parent</span><span style="color:#E6EDF3">() {</span></span>
<span class="line"><span style="color:#FF7B72">    return</span><span style="color:#E6EDF3"> (</span></span>
<span class="line"><span style="color:#E6EDF3">        &#x3C;</span><span style="color:#7EE787">BridgeProvider</span><span style="color:#E6EDF3">&#x3C;</span><span style="color:#FFA657">Messages</span><span style="color:#E6EDF3">></span></span>
<span class="line"><span style="color:#79C0FF">            open</span><span style="color:#FF7B72">={</span><span style="color:#79C0FF">true</span><span style="color:#FF7B72">}</span></span>
<span class="line"><span style="color:#79C0FF">            channelName</span><span style="color:#FF7B72">=</span><span style="color:#A5D6FF">"my-channel"</span></span>
<span class="line"><span style="color:#79C0FF">            role</span><span style="color:#FF7B72">=</span><span style="color:#A5D6FF">"parent"</span></span>
<span class="line"><span style="color:#79C0FF">            targetOrigin</span><span style="color:#FF7B72">=</span><span style="color:#A5D6FF">"https://child.example.com"</span></span>
<span class="line"><span style="color:#79C0FF">            enabledTransports</span><span style="color:#FF7B72">={</span><span style="color:#E6EDF3">[</span><span style="color:#A5D6FF">"post-message-channel"</span><span style="color:#E6EDF3">]</span><span style="color:#FF7B72">}</span></span>
<span class="line"><span style="color:#E6EDF3">        ></span></span>
